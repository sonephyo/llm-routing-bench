{
  "title": "vLLM Routing Metrics",
  "uid": "vllm-routing-001",
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Queue Depth (Requests)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "interval": "5s"
        }
      ]
    },
    {
      "id": 2,
      "title": "KV Cache Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "vllm:kv_cache_usage_perc",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 3,
      "title": "Time to First Token (p95)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(vllm:time_to_first_token_seconds_bucket[1m]))",
          "legendFormat": "{{backend}} p95",
          "refId": "A",
          "interval": "5s"
        }
      ]
    },
    {
      "id": 4,
      "title": "E2E Latency (p95)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(vllm:e2e_request_latency_seconds_bucket[1m]))",
          "legendFormat": "{{backend}} p95",
          "refId": "A",
          "interval": "5s"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "vllm:num_requests_running",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "interval": "5s"
        }
      ]
    },
    {
      "id": 6,
      "title": "Token Processing Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(vllm:generation_tokens_total[1m])",
          "legendFormat": "{{backend}} tokens/sec",
          "refId": "A",
          "interval": "5s"
        }
      ]
    }
  ]
}