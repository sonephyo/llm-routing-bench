{
  "title": "vLLM Routing Metrics",
  "uid": "vllm-routing-001",
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "1s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Queue Depth (Waiting + Running)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "vllm:num_requests_waiting + vllm:num_requests_running",
          "legendFormat": "{{backend}} total queued",
          "refId": "A",
          "interval": "1s"
        }
      ]
    },
    {
      "id": 2,
      "title": "KV Cache Usage (%)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "vllm:kv_cache_usage_perc",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "interval": "1s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 3,
      "title": "Time to First Token p95 (sec, 10s avg)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(vllm:time_to_first_token_seconds_bucket[10s]))",
          "legendFormat": "{{backend}} p95",
          "refId": "A",
          "interval": "1s"
        }
      ]
    },
    {
      "id": 4,
      "title": "E2E Request Latency p95 (sec, 10s avg)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(vllm:e2e_request_latency_seconds_bucket[10s]))",
          "legendFormat": "{{backend}} p95",
          "refId": "A",
          "interval": "1s"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Requests (Running)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "vllm:num_requests_running",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "interval": "1s"
        }
      ]
    },
    {
      "id": 6,
      "title": "Token Generation Rate (tokens/sec, 10s avg)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(vllm:generation_tokens_total[10s])",
          "legendFormat": "{{backend}} tokens/sec",
          "refId": "A",
          "interval": "1s"
        }
      ]
    },
{
      "id": 7,
      "title": "Inbound Request Rate per Backend (req/sec, 10s avg)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(lb_requests_total[10s])",
          "legendFormat": "{{backend}}",
          "interval": "1s"
        }
      ]
    },
    {
      "id": 8,
      "title": "vLLM Backend CPU Usage (cores/sec, 10s avg)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(process_cpu_seconds_total{job=~\"vllm-.*\"}[10s])",
          "legendFormat": "{{backend}} - {{instance}}",
          "interval": "1s"
        }
      ]
    },
    {
      "id": 9,
      "title": "Router CPU Usage (cores/sec, 10s avg)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(process_cpu_seconds_total{component=\"router\"}[10s])",
          "legendFormat": "router - {{instance}}",
          "interval": "1s"
        }
      ]
    }
  ]
}